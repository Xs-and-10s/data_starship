{deps, []}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_export_all,
    warn_unused_import,
    warn_unused_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, {git, "https://github.com/proper-testing/proper.git", {tag, "v1.5.0"}}}
        ]},
        {erl_opts, [nowarn_missing_spec]}
    ]}
]}.
